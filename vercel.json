{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/test-site/index.html" },
    { "source": "/game", "destination": "/2048遊戲/game.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
