{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/game", "destination": "/2048%E9%81%8A%E6%88%B2/game.html" },
    { "source": "/game/", "destination": "/2048%E9%81%8A%E6%88%B2/game.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
